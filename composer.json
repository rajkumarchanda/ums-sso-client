{
    "name": "ums/sso-client",
    "description": "Laravel client package for SmartExam SSO — verify tokens and authenticate users in consumer apps.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Raj Kumar Chanda",
            "email": "rajarajkumar.chanda@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SmartExam\\SsoClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmartExam\\SsoClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SmartExam\\SsoClient\\SmartExamSsoServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
